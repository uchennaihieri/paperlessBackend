generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  branch          String?   @db.VarChar(100)
  login_id        String?   @db.VarChar(50)
  user_no         String?   @db.VarChar(50)
  user_role       String?   @db.VarChar(50)
  employee_id     String?   @db.VarChar(50)
  user_name       String?   @db.VarChar(150)
  finca_email     String?   @db.VarChar(150)
  lock_flag       Boolean?
  effective_date  DateTime? @db.Date
  customer_number String?   @db.VarChar(50)
  creation_date   DateTime? @default(now()) @db.Timestamp()
  created_by      String?   @db.VarChar(50)
  status          String?   @db.VarChar(20)

  // System added fields
  signature        String?
  submissions      FormSubmission[]

  @@map("users")
}

model FormTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  mobileEnabled         Boolean @default(false)
  accountServicesEnabled Boolean @default(false)
  fields      Json
  htmlTemplate String? @db.Text // Store the raw HTML string template
  formOwner   String?  // The branch that owns/creates this form
  formTreater String?  // The branch responsible for treating/processing this form
  pdfGeneratorType String @default("none") // "none", "document", "html"
  pdfTemplateId    String?
  pdfTemplate      PdfTemplate? @relation(fields: [pdfTemplateId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submissions FormSubmission[]
  prerequisiteFor SubmissionPrerequisite[]
}

// Main form submission record
model FormSubmission {
  id             String              @id @default(cuid())
  reference      String?             @unique
  formName       String
  status         String              @default("Submitted") // Submitted, In-review, Processing, Awaiting Final Approval, Completed, Rejected
  formResponses  Json                // The actual field answers
  signingType    String              @default("sequential") // sequential | parallel
  treatedBy      String?             // Name of the officer who assigned to self and treated
  approvedBy     String?             // Display name of final approver, or "None"
  approverEmail  String?             // Email used to route to approver's queue
  submittedById  Int?
  submittedBy    User?               @relation(fields: [submittedById], references: [id])
  templateId     String
  template       FormTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  signatories    SubmissionSignatory[]
  documents      SubmissionDocument[]
  auditTrail     FormAuditTrail[]
  prerequisites      SubmissionPrerequisite[] @relation("MainSubmission")
  prerequisiteFor    SubmissionPrerequisite?  @relation("PrereqSubmission")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// Audit trail — one record per status transition on any submission
model FormAuditTrail {
  id            String         @id @default(cuid())
  submissionId  String
  submission    FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  formReference String?        // snapshot of submission.reference at time of event
  prevStatus    String
  newStatus     String
  action        String         // e.g. "signed", "declined", "assigned", "completed", "approved", "final_declined", "submitted"
  actorName     String?        // display name of the person who triggered the event
  actorEmail    String?        // email of the person who triggered the event
  note          String?        // optional context (e.g. decline reason, approver name routed to)
  createdAt     DateTime       @default(now())

  @@map("form_audit_trail")
}

// Documents uploaded as part of a submission — organised by form / reference
model SubmissionDocument {
  id           String         @id @default(cuid())
  submissionId String
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fieldName    String         // The form field label this file belongs to
  originalName String         // Original filename shown to users
  filePath     String         // SharePoint: "uploads/FORM/REF/file.ext" | Local: absolute path
  mimeType     String         @default("application/octet-stream")
  size         Int            @default(0)
  uploadedAt   DateTime       @default(now())

  @@map("submission_documents")
}

// Each signatory on a submission - ordered by position
model SubmissionSignatory {
  id             String         @id @default(cuid())
  submissionId   String
  submission     FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  position       Int            // 1 = first to sign, 2 = second, etc.
  userName       String
  email          String
  signedAt       DateTime?
  signatureToken String?
  signatureData  String?        @db.Text // Contains the base64 signature blob
  status         String         @default("Pending") // Pending, Signed, Declined
  declineReason  String?        @db.Text // Optional reason given when declining

  @@unique([submissionId, position])
}

model SubmissionPrerequisite {
  id                 String @id @default(cuid())
  mainSubmissionId   String
  mainSubmission     FormSubmission @relation("MainSubmission", fields: [mainSubmissionId], references: [id], onDelete: Cascade)
  
  prereqSubmissionId String? @unique // Populated when the prerequisite draft is created
  prereqSubmission   FormSubmission? @relation("PrereqSubmission", fields: [prereqSubmissionId], references: [id], onDelete: SetNull)
  
  targetFormId       String // The form template that must be filled
  targetForm         FormTemplate @relation(fields: [targetFormId], references: [id])
  
  targetEmail        String // Email of the person required to fill it
  
  status             String @default("Pending") // Pending, Submitted, Approved
  
  @@unique([mainSubmissionId, targetFormId, targetEmail])
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String
  expires DateTime

  @@unique([email, token])
}

model SecurityData {
  id                 String   @id @default(cuid())
  userEmail          String   @unique
  hashedToken        String
  encryptedSignature String   @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UploadedFile {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  filePath     String
  size         Int
  mimeType     String
  createdAt    DateTime @default(now())
}

model Report {
  id          String         @id @default(cuid())
  name        String
  description String         @db.Text
  script      String         @db.Text
  createdBy   String         // email of the Administrator who created it
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  access      ReportAccess[]

  @@map("reports")
}

// Join table: which users have access to which reports
model ReportAccess {
  id         String   @id @default(cuid())
  reportId   String
  userEmail  String
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  grantedAt  DateTime @default(now())

  @@unique([reportId, userEmail])
  @@map("report_access")
}

model PdfTemplate {
  id             String             @id @default(cuid())
  name           String             @unique
  type           String             @default("document") // "document" | "html"
  sharepointPath String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  fields         PdfTemplateField[]
  formTemplates  FormTemplate[]

  @@map("pdf_templates")
}

model PdfTemplateField {
  id          String      @id @default(cuid())
  templateId  String
  template    PdfTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name        String
  type        String      // "text", "image", "signature", etc.
  mappingPath String?     // e.g. "submitterEmail" or "Metadata.formTitle". If null, acts as Form Input
  page        Int         @default(0)
  x           Float       // Normalized 0-1
  y           Float       // Normalized 0-1
  width       Float       // Normalized 0-1
  height      Float       // Normalized 0-1
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("pdf_template_fields")
}

// Logs identity verification API responses to prevent multiple external API hits within 96 hours
model IdentityVerificationLog {
  id           String   @id @default(cuid())
  idType       String   // "bvn" or "nin"
  idNumber     String
  requestData  Json     // the payload sent (firstname, lastname, etc.)
  responseData Json     // the QoreID response
  verifiedBy   String   // Email of the user who performed it
  createdAt    DateTime @default(now())

  @@index([idType, idNumber])
  @@map("identity_verification_logs")
}
