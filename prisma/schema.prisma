generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                  @id @default(autoincrement())
  branch                  String?              @db.VarChar(100)
  login_id                String?              @db.VarChar(50)
  user_no                 String?              @db.VarChar(50)
  user_role               String?              @db.VarChar(50)
  employee_id             String?              @db.VarChar(50)
  user_name               String?              @db.VarChar(150)
  finca_email             String?              @db.VarChar(150)
  lock_flag               Boolean?
  effective_date          DateTime?            @db.Date
  customer_number         String?              @db.VarChar(50)
  creation_date           DateTime?            @default(now()) @db.Timestamp(6)
  created_by              String?              @db.VarChar(50)
  status                  String?              @db.VarChar(20)
  signature               String?
  mustResetPassword       Boolean              @default(true)
  passwordHash            String?
  passwordChangedAt       DateTime?
  specialAccess           String?              @db.VarChar(100)
  notificationPreferences Json?
  resetAttempts           Int                  @default(0)
  Event                   Event[]
  submissions             FormSubmission[]
  delegationsReceived     UserDelegation[]     @relation("Delegatee")
  delegationsGiven        UserDelegation[]     @relation("Delegator")
  devices                 DeviceRegistration[]

  @@map("users")
}

model UserDelegation {
  id             String   @id @default(cuid())
  originalUserId Int
  delegateUserId Int
  status         String   @default("Pending")
  initiatedBy    String   @default("User")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  delegateUser   User     @relation("Delegatee", fields: [delegateUserId], references: [id], onDelete: Cascade)
  originalUser   User     @relation("Delegator", fields: [originalUserId], references: [id], onDelete: Cascade)
}

model FormTemplate {
  id                     String                   @id @default(cuid())
  name                   String                   @unique
  description            String?
  fields                 Json
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  formOwner              String?
  formTreater            String?
  htmlTemplate           String?
  pdfGeneratorType       String                   @default("none")
  pdfTemplateId          String?
  mobileEnabled          Boolean                  @default(false)
  accountServicesEnabled Boolean                  @default(false)
  isInternal             Boolean                  @default(false)
  contractTemplateId     String?
  needsContract          Boolean                  @default(false)
  generatesExcel         Boolean                  @default(false)
  formTreaterRole        String?
  automatedSignatories   Json?
  automatedSigningType   String?
  isPublic               Boolean                  @default(false)
  publicSlug             String?                  @unique
  templateMappings       Json?
  requestBatches         FormRequestBatch[]
  submissions            FormSubmission[]
  pdfTemplate            PdfTemplate?             @relation(fields: [pdfTemplateId], references: [id])
  prerequisiteFor        SubmissionPrerequisite[]
  formAccess             FormAccess[]
}

model FormSubmission {
  id                   String                   @id @default(cuid())
  formName             String
  status               String                   @default("Submitted")
  formResponses        Json
  submittedById        Int?
  templateId           String
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  signingType          String                   @default("sequential")
  reference            String?                  @unique
  approvedBy           String?
  treatedBy            String?
  approverEmail        String?
  treaterEmail         String?
  alias                String?
  publicSubmitterEmail String?
  publicSubmitterName  String?
  requestBatchId       String?
  eventAsMaster        Event?                   @relation("MasterSubmission")
  submittedBy          User?                    @relation(fields: [submittedById], references: [id])
  template             FormTemplate             @relation(fields: [templateId], references: [id], onDelete: Cascade)
  prerequisites        SubmissionPrerequisite[] @relation("MainSubmission")
  prerequisiteFor      SubmissionPrerequisite?  @relation("PrereqSubmission")
  signatories          SubmissionSignatory[]
  contractRequests     ContractRequest[]
  auditTrail           FormAuditTrail[]
  documents            SubmissionDocument[]
}

model FormAuditTrail {
  id            String         @id @default(cuid())
  submissionId  String
  formReference String?
  prevStatus    String
  newStatus     String
  action        String
  actorName     String?
  actorEmail    String?
  note          String?
  createdAt     DateTime       @default(now())
  submission    FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("form_audit_trail")
}

model SubmissionDocument {
  id           String         @id @default(cuid())
  submissionId String
  fieldName    String
  originalName String
  filePath     String
  mimeType     String         @default("application/octet-stream")
  size         Int            @default(0)
  uploadedAt   DateTime       @default(now())
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_documents")
}

model SubmissionSignatory {
  id              String         @id @default(cuid())
  submissionId    String
  position        Int
  userName        String
  email           String
  signedAt        DateTime?
  signatureToken  String?
  status          String         @default("Pending")
  signatureData   String?
  declineReason   String?
  annotations     Json?
  approvalComment String?
  submission      FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, position])
}

model SubmissionPrerequisite {
  id                 String          @id @default(cuid())
  mainSubmissionId   String
  prereqSubmissionId String?         @unique
  targetFormId       String?
  targetEmail        String?
  status             String          @default("Pending")
  type               String          @default("FORM")
  contractRequestId  String?
  order              Int             @default(1)
  declineReason      String?
  mainSubmission     FormSubmission  @relation("MainSubmission", fields: [mainSubmissionId], references: [id], onDelete: Cascade)
  prereqSubmission   FormSubmission? @relation("PrereqSubmission", fields: [prereqSubmissionId], references: [id])
  targetForm         FormTemplate?   @relation(fields: [targetFormId], references: [id])

  @@index([mainSubmissionId])
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String
  expires DateTime

  @@unique([email, token])
}

model SecurityData {
  id                 String   @id @default(cuid())
  hashedToken        String
  encryptedSignature String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  userEmail          String   @unique
}

model UploadedFile {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  filePath     String
  size         Int
  mimeType     String
  createdAt    DateTime @default(now())
}

model Report {
  id             String         @id @default(cuid())
  name           String
  description    String
  script         String?
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  formStatuses   Json?
  formTemplateId String?
  reportType     String         @default("manual")
  access         ReportAccess[]

  @@map("reports")
}

model ReportAccess {
  id        String   @id @default(cuid())
  reportId  String
  userEmail String
  grantedAt DateTime @default(now())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, userEmail])
  @@map("report_access")
}

model PdfTemplate {
  id             String             @id @default(cuid())
  name           String             @unique
  sharepointPath String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  type           String             @default("document")
  availableFor   String[]           @default(["forms"])
  Event          Event[]
  formTemplates  FormTemplate[]
  fields         PdfTemplateField[]

  @@map("pdf_templates")
}

model PdfTemplateField {
  id          String      @id @default(cuid())
  templateId  String
  name        String
  type        String
  page        Int         @default(0)
  x           Float
  y           Float
  width       Float
  height      Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  mappingPath String?
  template    PdfTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("pdf_template_fields")
}

model IdentityVerificationLog {
  id           String   @id @default(cuid())
  idType       String
  idNumber     String
  requestData  Json
  responseData Json
  verifiedBy   String
  createdAt    DateTime @default(now())
  reference    String   @unique
  status       String   @default("Verified")
  subjectName  String   @default("")
  pdfPath      String?

  @@index([idType, idNumber])
  @@index([idType])
  @@map("identity_verification_logs")
}

model FormAccess {
  id         String       @id @default(cuid())
  templateId String
  userEmail  String
  grantedAt  DateTime     @default(now())
  grantedBy  String
  template   FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, userEmail])
  @@map("form_access")
}

model JournalEntry {
  id                String           @id @default(cuid())
  entryId           String           @unique
  committed         Boolean          @default(false)
  sessionRef        String
  formName          String
  type              String
  accountCode       String
  accountName       String
  batchNumber       String?
  branch            String?
  description       String
  amount            Decimal          @db.Decimal(18, 2)
  createdBy         String
  date              DateTime         @default(now())
  batchGroupId      String?
  journalId         String?          @db.VarChar(50)
  uploadedJournalId String?
  uploadedJournal   UploadedJournal? @relation(fields: [uploadedJournalId], references: [id])

  @@index([sessionRef])
  @@index([committed])
  @@index([batchGroupId])
  @@index([uploadedJournalId])
  @@map("journal_entries")
}

model DeviceRegistration {
  id           String    @id @default(cuid())
  userId       Int
  deviceId     String
  deviceName   String?
  status       String    @default("Pending")
  approvedBy   String?
  registeredAt DateTime  @default(now())
  approvedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@map("device_registrations")
}

model LookupValue {
  id        String   @id @default(cuid())
  type      String   @db.VarChar(50)
  value     String   @db.VarChar(150)
  createdAt DateTime @default(now())

  @@unique([type, value])
  @@map("lookup_values")
}

model CreditBureauLog {
  id            String   @id @default(cuid())
  reference     String   @unique
  bureau        String
  bvn           String
  subjectName   String   @default("")
  status        String   @default("Match Found")
  matchCount    Int      @default(0)
  enquiryReason String   @default("Credit Check")
  productId     Int      @default(45)
  pdfPath       String?
  requestData   Json
  responseData  Json
  verifiedBy    String
  createdAt     DateTime @default(now())
  reportData    Json?

  @@index([bureau])
  @@index([bvn])
  @@map("credit_bureau_logs")
}

model ReusableList {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  items       Json
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reusable_lists")
}

model ContractRequest {
  id                     String         @id @default(cuid())
  submissionId           String
  templateId             String
  submitterEmail         String
  status                 String         @default("Pending")
  signedAt               DateTime?
  signatureToken         String?
  pdfPath                String?
  createdAt              DateTime       @default(now())
  internalSignature      String?
  internalSignerJobTitle String?
  externalSignerName     String?
  externalSignerEmail    String?
  externalToken          String?        @unique
  externalSignedAt       DateTime?
  externalSignature      String?
  submission             FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("contract_requests")
}

model AppVersion {
  id           String   @id @default(cuid())
  version      String
  downloadUrl  String
  releaseNotes String?
  publishedAt  DateTime @default(now())
  publishedBy  String
  updatedAt    DateTime @updatedAt

  @@map("app_versions")
}

model UploadedJournal {
  id               String         @id @default(cuid())
  uploadId         String         @unique
  fileName         String
  sharepointPath   String
  totalDebit       Decimal        @db.Decimal(18, 2)
  totalCredit      Decimal        @db.Decimal(18, 2)
  uploadedBy       String
  uploadedAt       DateTime       @default(now())
  linkedSessionRef String?
  entries          JournalEntry[]

  @@index([uploadedAt])
  @@index([linkedSessionRef])
  @@map("uploaded_journals")
}

model PdfJobQueue {
  id                 String   @id @default(uuid())
  sourceSubmissionId String
  jobType            String
  targetSubmissionId String?
  targetFieldName    String?
  status             String   @default("Pending")
  errorMsg           String?
  attempts           Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("pdf_job_queue")
}

model FormRequestBatch {
  id            String        @id @default(cuid())
  templateId    String
  requestedBy   String
  message       String?
  prefilledData Json?
  status        String        @default("Pending")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  requests      FormRequest[]
  template      FormTemplate  @relation(fields: [templateId], references: [id])
}

model FormRequest {
  id           String           @id @default(cuid())
  batchId      String
  targetEmail  String
  token        String           @unique
  status       String           @default("Pending")
  submissionId String?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  batch        FormRequestBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model Event {
  id                 String             @id @default(cuid())
  reference          String             @unique
  name               String
  startDate          DateTime
  endDate            DateTime
  pdfTemplateId      String?
  documentUrl        String?
  createdById        Int?
  createdAt          DateTime           @default(now())
  masterSubmissionId String?            @unique
  templateMappings   Json?
  createdBy          User?              @relation(fields: [createdById], references: [id])
  masterSubmission   FormSubmission?    @relation("MasterSubmission", fields: [masterSubmissionId], references: [id])
  pdfTemplate        PdfTemplate?       @relation(fields: [pdfTemplateId], references: [id])
  facilitators       EventFacilitator[]
}

model EventFacilitator {
  id      String @id @default(cuid())
  eventId String
  email   String
  name    String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model UploadedDataset {
  id                String          @id @default(cuid())
  name              String
  uploadedBy        String
  sharedWith        String[]
  headers           String[]        @default([])
  status            String
  createdAt         DateTime        @default(now())
  runCreditRegistry Boolean         @default(false)
  runFirstCentral   Boolean         @default(false)
  records           DatasetRecord[]
}

model DatasetRecord {
  id                String          @id @default(cuid())
  datasetId         String
  reference         String          @unique
  bvn               String?
  rowData           Json
  firstCentralRef   String?
  creditRegistryRef String?
  processingStatus  String
  dataset           UploadedDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model CrmInteraction {
  id            String   @id @default(cuid())
  customerPhone String
  sourceType    String
  sourceId      String
  feedbackText  String
  status        String
  loggedByEmail String
  loggedByName  String
  createdAt     DateTime @default(now())
}

model PdfTemp {
  id        String   @id @default(cuid())
  pdfBuffer Bytes
  createdAt DateTime @default(now())
}
